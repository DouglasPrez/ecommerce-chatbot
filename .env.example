# Puerto en el que correrá la aplicación
# Default: 3000
PORT=3000

# Configuración de Base de Datos PostgreSQL
# Estas credenciales deben coincidir con tu instalación local de PostgreSQL
# o con las credenciales definidas en docker-compose.yml

# Usuario de la base de datos
# Default: ebot_user
DB_USER=ebot_user

# Contraseña del usuario de la base de datos
# Default: ebot_password
DB_PASSWORD=ebot_password

# Host donde corre PostgreSQL
# Usa 'localhost' para instalación local
# Usa 'postgres' si corres con docker-compose
# Default: localhost
DB_HOST=localhost

# Nombre de la base de datos
# Default: ebot
DB_NAME=ebot

# Puerto de PostgreSQL
# Default: 5432
DB_PORT=5432

# Entorno de ejecución
# Valores válidos: development, production, test
# Default: development
NODE_ENV=development